APP_ENVIRONMENT=development
DEBUG=false

# Local development HTTP uchun false. Production HTTPS muhitida true bo'lishi shart.
SESSION_COOKIE_NAME=nasiya_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_DAYS=30
ANONYMOUS_SESSION_TTL_MINUTES=30
SESSION_TOUCH_INTERVAL_MINUTES=5

PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_PHONE_ATTEMPTS=5
LOGIN_RATE_LIMIT_IP_ATTEMPTS=20

# Development namunasi xolos. Productionda real, maxfiy, kamida 32 belgili qiymat bering.
RATE_LIMIT_HMAC_KEY=change-me-local-rate-limit-hmac-key-at-least-32-chars

# PostgreSQL compose service values
POSTGRES_DB=nasiya
POSTGRES_USER=nasiya
POSTGRES_PASSWORD=dev_pass
POSTGRES_PORT=5432

# Host kompyuterda app ishga tushsa, PostgreSQL published port orqali ulanadi.
DB_HOST_LOCAL=127.0.0.1
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST_LOCAL}:${POSTGRES_PORT}/${POSTGRES_DB}
TEST_DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST_LOCAL}:${POSTGRES_PORT}/nasiya_test

# Docker ichidagi app esa compose service hostname va ichki 5432 portdan foydalanadi.
DB_HOST_DOCKER=db
DATABASE_URL_DOCKER=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST_DOCKER}:5432/${POSTGRES_DB}
